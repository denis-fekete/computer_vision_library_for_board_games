<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
        xmlns:android = "http://schemas.android.com/apk/res/android"
        xmlns:tools = "http://schemas.android.com/tools"
        xmlns:app = "http://schemas.android.com/apk/res-auto"
        android:id = "@+id/main"
        tools:context = ".MainActivity"
        android:layout_width = "match_parent"
        android:layout_height = "match_parent"
        android:orientation = "vertical"
        android:fitsSystemWindows = "false">

    <androidx.fragment.app.FragmentContainerView
            android:id = "@+id/navHostContainer"
            android:name = "androidx.navigation.fragment.NavHostFragment"
            android:layout_width = "match_parent"
            android:layout_height = "match_parent"
            app:defaultNavHost = "true"
            app:navGraph = "@navigation/nav_graph"
            app:layout_constraintTop_toTopOf = "parent"
            app:layout_constraintBottom_toTopOf = "parent"
            app:layout_constraintStart_toStartOf = "parent"
            app:layout_constraintEnd_toEndOf = "parent"/>

    <LinearLayout
            android:id = "@+id/navigationPanel"
            android:layout_width = "match_parent"
            android:layout_height = "48dp"
            app:layout_constraintBottom_toBottomOf = "parent"
            app:layout_constraintStart_toStartOf = "parent"
            app:layout_constraintEnd_toEndOf = "parent"
            android:layout_marginBottom = "32dp"
            android:weightSum = "3">


        <ImageButton
                android:id = "@+id/btnNavSearch"
                android:layout_width = "0dp"
                android:layout_height = "match_parent"
                android:layout_weight = "1"
                android:src = "@drawable/search"
                android:contentDescription = "Benchmark Icon"
                app:tint = "@color/navigation_icon_tint"
                android:background = "@null"
                android:clickable = "true"
                android:focusable = "true"
                android:foreground = "?attr/selectableItemBackground"
                />

        <ImageButton
                android:id = "@+id/btnNavCamera"
                android:layout_width = "0dp"
                android:layout_height = "match_parent"
                android:layout_weight = "1"
                android:src = "@drawable/camera"
                android:contentDescription = "Camera Icon"
                app:tint = "@color/navigation_icon_tint"
                android:background = "@null"
                android:clickable = "true"
                android:focusable = "true"
                android:foreground = "?attr/selectableItemBackground"
                />

        <ImageButton
                android:id = "@+id/btnNavSettings"
                android:layout_width = "0dp"
                android:layout_height = "match_parent"
                android:src = "@drawable/settings"
                android:contentDescription = "Settings Icon"
                app:tint = "@color/navigation_icon_tint"
                android:layout_weight = "1"
                android:background = "@null"
                android:clickable = "true"
                android:focusable = "true"
                android:foreground = "?attr/selectableItemBackground"
                />
    </LinearLayout>


    <androidx.fragment.app.FragmentContainerView
            android:id = "@+id/inventoryContainer"
            android:name = "com.fekete.bangdemo.fragments.InventoryFragment"
            android:layout_width = "match_parent"
            android:layout_height = "160dp"
            app:layout_constraintBottom_toTopOf = "@id/navigationPanel"
            app:layout_constraintStart_toStartOf = "parent"
            app:layout_constraintEnd_toEndOf = "parent"
            android:layout_marginBottom = "100dp"/>

    <androidx.fragment.app.FragmentContainerView
            android:id = "@+id/characterAndRoleContainer"
            android:name = "com.fekete.bangdemo.fragments.CharacterAndRoleFragment"
            android:layout_width = "200dp"
            android:layout_height = "100dp"
            app:layout_constraintEnd_toEndOf = "parent"
            app:layout_constraintTop_toTopOf = "parent"
            android:layout_marginTop = "8dp"
            android:layout_marginEnd = "8dp"/>


</androidx.constraintlayout.widget.ConstraintLayout>